{
  "manifest_version": 3,
  "name": "Spoiler Shield: Hide Reddit Spoilers",
  "short_name": "Spoiler Shield",
  "version": "0.6.0",
  "description": "Blur Reddit spoilers by topic — World Cup, F1, TV shows. Toggle until you've watched; posts blur even from subs you don't follow.",
  "homepage_url": "https://github.com/ArpitKubadia/spoiler-shield",
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Spoiler Shield"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://www.reddit.com/*", "*://sh.reddit.com/*"],
      "run_at": "document_start",
      "js": [
        "src/shared/matching.js",
        "src/shared/storage.js",
        "src/content/adapters/reddit.js",
        "src/content/engine.js",
        "src/content/index.js"
      ],
      "css": ["src/content/content.css"]
    }
  ]
}
