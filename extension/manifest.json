{
  "manifest_version": 3,
  "name": "Spoiler Shield",
  "version": "0.4.0",
  "description": "Blur spoiler posts on Reddit by toggleable topic (subreddit patterns + keywords).",
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Spoiler Shield"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://www.reddit.com/*", "*://sh.reddit.com/*"],
      "run_at": "document_start",
      "js": [
        "src/shared/matching.js",
        "src/shared/storage.js",
        "src/content/adapters/reddit.js",
        "src/content/engine.js",
        "src/content/index.js"
      ],
      "css": ["src/content/content.css"]
    }
  ]
}
